@TradingJournal_HostAddress = http://localhost:5075

# Add a new trade
POST {{TradingJournal_HostAddress}}/api/trades/add
Content-Type: application/json

{
  "symbol": "RELIANCE",
  "instrumentType": "Equity",
  "tradeType": "Buy",
  "entryPrice": 2450.50,
  "exitPrice": 2450.50,
  "quantity": 100,
  "stoploss": 2420.00,
  "target": 2500.00,
  "entryTime": "2025-01-20T09:25:00Z",
  "exitTime": "2025-01-21T13:45:00Z",
  "charges": 35.50,
  "strategy": "Breakout",
  "setup": "Opening Range Breakout",
  "notes": "Clean breakout with volume confirmation"
}


###

# Get all trades
GET {{TradingJournal_HostAddress}}/api/trades/getdata
Accept: application/json

